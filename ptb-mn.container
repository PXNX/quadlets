[Unit]
Description="ptb-mn"
After=local-fs.target

[Container]
Image=docker.io/library/python:3.12-slim
AutoUpdate=registry
ContainerName=ptb-mn

WorkingDir=/app
Volume=%h/projects/ptb-mn/bot:/app:Z

EnvironmentFile=%h/projects/ptb-mn/.env
Environment=CONTAINER=true

Exec=sh -c "pip install --no-cache-dir -r requirements.txt && python main.py"

Network=host

[Service]
Restart=always

[Install]
WantedBy=default.target